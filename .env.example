# Copy to `.env.local` and fill values. Client-exposed keys must use `NEXT_PUBLIC_`.

# WalletConnect / Reown Cloud — required for RainbowKit mobile & WalletConnect wallets
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=1a2415b0535b6db4f78178927c4171de

# Default chain hint for app logic (optional; e.g. 1, 11155111, 31337 Hardhat, 5042002 Arc Testnet)
NEXT_PUBLIC_CHAIN_ID=31337

# Single RPC URL fallback (optional; used where `publicEnv.rpcUrl` is read)
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Per-chain RPC (optional; defaults in `lib/web3/chains.ts`)
NEXT_PUBLIC_RPC_MAINNET=
NEXT_PUBLIC_RPC_SEPOLIA=
# Hardhat local (chainId 31337); omit to use default http://127.0.0.1:8545
NEXT_PUBLIC_RPC_HARDHAT=http://127.0.0.1:8545
# Arc Testnet (chainId 5042002); omit to use https://rpc.testnet.arc.network — see https://docs.arc.network/arc/references/connect-to-arc
NEXT_PUBLIC_RPC_ARC_TESTNET=

# Factory contract (optional until you deploy / point at a known address)
NEXT_PUBLIC_ERCS20_FACTORY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# Legacy alias supported in code:
# NEXT_PUBLIC_ERC20_FACTORY_ADDRESS=

# Default ERCS-20 token address for UI (optional)
NEXT_PUBLIC_DEFAULT_ERCS20_TOKEN=0xa16E02E87b7454126E5E10d957A927A7F5B5d2be

# Asset vault for spot deposit (optional until deployed)
NEXT_PUBLIC_SPOT_ASSET_VAULT_ADDRESS=

# WUSDC — spot ledger token for native USDC (UI zero address → this address for balance API)
NEXT_PUBLIC_WUSDC_ADDRESS=0xcf7ed3acca5a467e9e704c703e8d87f634fb0fc9

# Backend REST API (optional until Phase 2 spot/order APIs are wired)
# Origin only — version prefix is separate (see NEXT_PUBLIC_API_PATH_PREFIX)
NEXT_PUBLIC_API_BASE_URL=
# Global path prefix prepended by lib/api/client.ts (default: /api/v1)
NEXT_PUBLIC_API_PATH_PREFIX=/api/v1

# EIP-712 login signature domain (optional; defaults match spot-users application.yml)
# NEXT_PUBLIC_EIP712_LOGIN_NAME=Orbix exchange
# NEXT_PUBLIC_EIP712_LOGIN_VERSION=1
# NEXT_PUBLIC_EIP712_LOGIN_CHAIN_ID=31337
