# Copy to `.env.local` and fill values. Client-exposed keys must use `NEXT_PUBLIC_`.

# WalletConnect / Reown Cloud — required for RainbowKit mobile & WalletConnect wallets
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=1a2415b0535b6db4f78178927c4171de

# Default chain hint for app logic (optional; e.g. 1, 11155111, or 31337 for Hardhat)
NEXT_PUBLIC_CHAIN_ID=31337

# Single RPC URL fallback (optional; used where `publicEnv.rpcUrl` is read)
NEXT_PUBLIC_RPC_URL=http://192.168.31.147:8545
NEXT_PUBLIC_EXPLORER_URL=https://explorer.testnet.arc.network

# Per-chain RPC (optional; preferred by `getRpcUrl` for mainnet / Sepolia / Hardhat)
NEXT_PUBLIC_RPC_MAINNET=
NEXT_PUBLIC_RPC_SEPOLIA=
# Hardhat local (chainId 31337); omit to use default http://127.0.0.1:8545
NEXT_PUBLIC_RPC_HARDHAT=http://192.168.31.147:8545

# Arc Testnet
NEXT_PUBLIC_RPC_ARC_TESTNET=https://rpc.testnet.arc.network

# Factory contract (optional until you deploy / point at a known address)
NEXT_PUBLIC_ERCS20_FACTORY_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
# Legacy alias supported in code:
# NEXT_PUBLIC_ERC20_FACTORY_ADDRESS=

# Default ERCS-20 token address for UI (optional) - OBX
NEXT_PUBLIC_DEFAULT_ERCS20_TOKEN=0xCafac3dD18aC6c6e92c921884f9E4176737C052c

# GlobalSpotVault for spot deposit
NEXT_PUBLIC_SPOT_ASSET_VAULT_ADDRESS=0x0165878a594ca255338adfa4d48449f69242eb8f

# SpotPairFactory
NEXT_PUBLIC_SPOT_PAIR_FACTORY=0x2279b7a0a67db372996a5fab50d91eaa73d2ebe6

# WUSDC — spot ledger token for native USDC (UI zero address → this address for balance API)
NEXT_PUBLIC_WUSDC_ADDRESS=0xcf7ed3acca5a467e9e704c703e8d87f634fb0fc9

# SpotExchange — EIP-712 verifying contract for place/cancel order
NEXT_PUBLIC_SPOT_EXCHANGE_ADDRESS=0xdc64a140aa3e981100a9beca4e685f962f0cf6c9

# Default pair for spot
NEXT_PUBLIC_SPOT_DEFAULT_BASE_TOKEN_SYMBOL=OBX
NEXT_PUBLIC_SPOT_DEFAULT_QUOTE_TOKEN_SYMBOL=USDC

# API base URL (optional)
NEXT_PUBLIC_API_BASE_URL=http://192.168.31.147:8088
# Global REST prefix (optional)
NEXT_PUBLIC_API_PATH_PREFIX=/api/v1/

# EIP-712 login signature domain (optional; defaults match spot-users application.yml)
NEXT_PUBLIC_EIP712_LOGIN_NAME=Orbix exchange
NEXT_PUBLIC_EIP712_LOGIN_VERSION=1

# EIP-712 withdraw signature domain (optional; defaults match spot-orders application.yml)
NEXT_PUBLIC_EIP712_WITHDRAW_NAME=SpotWithdrawals
NEXT_PUBLIC_EIP712_WITHDRAW_VERSION=1

# EIP-712 place-order signature domain (optional; defaults match spot-orders application.yml)
NEXT_PUBLIC_EIP712_SPOT_EXCHANGE_NAME=SpotExchange
NEXT_PUBLIC_EIP712_SPOT_EXCHANGE_VERSION=1

# EIP-712 cancel-order signature domain (optional; same exchange domain as place-order)
# NEXT_PUBLIC_EIP712_CANCEL_ORDER_NAME=SpotExchange
# NEXT_PUBLIC_EIP712_CANCEL_ORDER_VERSION=1

# Spot order defaults (optional; align with spot-orders application.yml)
NEXT_PUBLIC_ORDER_TIME_IN_FORCE_GT=1
NEXT_PUBLIC_SPOT_ORDER_GTC_EXPIRY_DAYS=31
NEXT_PUBLIC_DEFAULT_DECIMALS=18